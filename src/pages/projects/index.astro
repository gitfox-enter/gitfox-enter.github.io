---
import { Button, Icon } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'
import ProjectSection from '@/components/projects/ProjectSection.astro'
import Sponsorship from '@/components/projects/Sponsorship.astro'
import wechat from '@/assets/images/wechat-tip.jpg'
import { getProjects, getProjectStats } from '@/lib/projects'

const projects = getProjects()
const stats = getProjectStats()

const headings = [
  { depth: 2, slug: 'programs', text: '开源项目' },
  { depth: 2, slug: 'github', text: 'GitHub 活动' },
  { depth: 2, slug: 'sponsorship', text: '赞助' }
]
---

<PageLayout title='项目' {headings} view>
  <p>目前在 GitHub 上维护的几个项目，欢迎 Star / Fork / Issue。</p>

  <h2 id='programs'>开源项目</h2>
  <ProjectSection
    projects={projects.map(project => ({
      name: `${project.name}${project.stars > 0 ? ` ⭐ ${project.stars}` : ''}`,
      description: project.description,
      links: [
        { type: 'github', href: project.url },
        ...(project.homepage ? [{ type: 'site' as const, href: project.homepage }] : [])
      ]
    }))}
  />

  <h2 id='github'>GitHub 活动</h2>
  <p>
    <img
      src={`https://ghchart.rshah.org/659eb9/gitfox-enter`}
      alt='GitHub contributions'
      loading='lazy'
      style='width: 100%; border-radius: 8px;'
    />
  </p>
  <p>
    <Button title='访问我的 GitHub' href='https://github.com/gitfox-enter' target='_blank'>
      <Icon class='size-5' name='github' slot='before' />
    </Button>
  </p>

  <h2 id='sponsorship'>赞助</h2>
  <p>
    如果我的内容对你有所帮助，欢迎请我喝杯咖啡 ☕。
    你的支持是我持续输出的动力！
  </p>

  <p>国内方式：微信赞赏</p>
  <Sponsorship
    methods={[
      { name: '微信赞赏', icon: 'wechat-pay', image: wechat }
    ]}
  />
</PageLayout>
