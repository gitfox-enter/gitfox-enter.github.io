---
import PageLayout from '@/layouts/CommonPage.astro'
import Sponsorship from '@/components/projects/Sponsorship.astro'
import wechat from '@/assets/images/wechat-tip.jpg'
import projectConfig from '@/data/project-config.json'

const categories = (projectConfig as any).categories as Record<string, { title: string; description: string }>
const projects = (projectConfig as any).projects as Record<string, any>

const headings = [
  { depth: 2, slug: 'applications', text: '应用项目' },
  { depth: 2, slug: 'programs', text: '自动化脚本' },
  { depth: 2, slug: 'learnings', text: '学习项目' },
  { depth: 2, slug: 'github', text: 'GitHub 活动' },
  { depth: 2, slug: 'roadmap', text: '学习路线' },
  { depth: 2, slug: 'sponsorship', text: '赞助' }
]

// Group projects by category
const grouped: Record<string, any[]> = {}
for (const [key, proj] of Object.entries(projects) as [string, any][]) {
  const cat = proj.category || 'other'
  if (!grouped[cat]) grouped[cat] = []
  grouped[cat].push(proj)
}

const categoryOrder = ['applications', 'programs', 'learnings']

const roadmap = [
  { step: 1, name: '学习笔记仓库', status: 'done', repo: 'github-learning-notes', desc: '熟悉 GitHub 基础操作、Markdown、Git 提交流程' },
  { step: 2, name: '个人名片页', status: 'current', desc: '学会 HTML + CSS + GitHub Pages 部署' },
  { step: 3, name: 'Todo 待办清单', status: 'todo', desc: '入门 JavaScript + 分支操作 + commit 规范' },
  { step: 4, name: 'Python 小脚本', status: 'todo', desc: '接触后端逻辑 + CLI 开发' },
  { step: 5, name: '天气查询页面', status: 'todo', desc: '前后端交互 + API 调用' }
]
---

<PageLayout title='项目' {headings} view>
  <p>以下是我在 GitHub 上的项目，按类型分类展示。</p>

  {categoryOrder.map((catKey: string) => {
    const cat = (categories as any)[catKey] as { title: string; description: string } | undefined
    const items = grouped[catKey] || []
    if (!cat || items.length === 0) return null
    return (
      <>
        <h2 id={catKey}>{cat.title}</h2>
        <p class="category-desc">{cat.description}</p>
        <div class="project-grid">
          {items.map((proj: any) => {
            const link = proj.repo ? `https://github.com/${proj.repo}` : (proj.homepage || '#')
            return (
              <a class="project-card" href={link} target="_blank" rel="noopener noreferrer">
                <div class="card-header">
                  <span class="card-title">{proj.title}</span>
                  <span class="card-subtitle">{proj.subtitle}</span>
                </div>
                <p class="card-desc">{proj.customDescription || ''}</p>
                {proj.tags && proj.tags.length > 0 && (
                  <div class="card-tags">
                    {proj.tags.map((tag: string) => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                )}
              </a>
            )
          })}
        </div>
      </>
    )
  })}

  <h2 id="github">GitHub 活动</h2>
  <p>
    <img
      src={`https://ghchart.rshah.org/659eb9/gitfox-enter`}
      alt='GitHub contributions chart for gitfox-enter'
      width='100%'
      loading='lazy'
      style='width: 100%; border-radius: 8px;'
    />
  </p>

  <h2 id="roadmap">学习路线</h2>
  <p>从零开始系统学习 GitHub 的进度，每个阶段对应一个实际项目。</p>
  <div class="roadmap">
    {roadmap.map((item: any) => (
      <div class:list={['roadmap-item', item.status]}>
        <div class="roadmap-marker">
          {item.status === 'done' && '✅'}
          {item.status === 'current' && '🔄'}
          {item.status === 'todo' && '⬜'}
        </div>
        <div class="roadmap-content">
          <div class="roadmap-title">
            <span class="step-badge">Step {item.step}</span>
            {item.name}
            {item.repo && <a href={`https://github.com/gitfox-enter/${item.repo}`} target="_blank" class="repo-link">→ 仓库</a>}
          </div>
          <p class="roadmap-desc">{item.desc}</p>
        </div>
      </div>
    ))}
  </div>

  <h2 id="sponsorship">赞助</h2>
  <p>
    如果我的内容对你有所帮助，欢迎请我喝杯咖啡 ☕。
    你的支持是我持续输出的动力！
  </p>
  <p>国内方式：微信赞赏</p>
  <Sponsorship
    methods={[
      { name: '微信赞赏', icon: 'wechat-pay', image: wechat }
    ]}
  />
</PageLayout>

<style>
  .category-desc {
    color: hsl(var(--muted-foreground));
    font-size: 0.875rem;
    margin-bottom: 0.75rem;
  }

  .project-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  @media (min-width: 640px) {
    .project-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .project-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1rem;
    border-radius: 0.75rem;
    border: 1px solid hsl(var(--border));
    text-decoration: none;
    color: inherit;
    transition: all 0.2s;
  }

  .project-card:hover {
    background-color: hsl(var(--muted));
    border-color: hsl(var(--primary) / 0.3);
    transform: translateY(-2px);
  }

  .card-header {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .card-title {
    font-weight: 600;
    font-size: 1rem;
    color: hsl(var(--foreground));
    transition: color 0.2s;
  }

  .project-card:hover .card-title {
    color: hsl(var(--primary));
  }

  .card-subtitle {
    font-size: 0.8125rem;
    color: hsl(var(--muted-foreground));
  }

  .card-desc {
    font-size: 0.875rem;
    line-height: 1.5;
    color: hsl(var(--muted-foreground));
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-top: 0.25rem;
  }

  .tag {
    font-size: 0.75rem;
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
    border: 1px solid hsl(var(--primary) / 0.2);
    background: hsl(var(--primary) / 0.05);
    color: hsl(var(--primary));
  }

  .roadmap {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 0.5rem;
  }

  .roadmap-item {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .roadmap-marker {
    flex-shrink: 0;
    width: 2rem;
    height: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
  }

  .roadmap-content {
    flex: 1;
  }

  .roadmap-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 500;
    flex-wrap: wrap;
  }

  .step-badge {
    font-size: 0.6875rem;
    padding: 0.0625rem 0.375rem;
    border-radius: 0.25rem;
    background: hsl(var(--muted));
    color: hsl(var(--muted-foreground));
    font-weight: 400;
  }

  .repo-link {
    font-size: 0.8125rem;
    color: hsl(var(--primary));
    text-decoration: none;
  }

  .repo-link:hover {
    opacity: 0.8;
  }

  .roadmap-desc {
    font-size: 0.875rem;
    color: hsl(var(--muted-foreground));
    margin-top: 0.25rem;
  }

  .roadmap-item.current .roadmap-title {
    color: hsl(var(--primary));
  }
</style>
