---
import PageLayout from '@/layouts/CommonPage.astro'
import Sponsorship from '@/components/projects/Sponsorship.astro'
import wechat from '@/assets/images/wechat-tip.jpg'
import projectConfig from '@/data/project-config.json'

const categories = (projectConfig as any).categories as Record<string, { title: string; description: string }>
const projects = (projectConfig as any).projects as Record<string, any>

const categoryOrder = ['applications', 'programs', 'learnings', 'others']

const headings: any[] = [
  { depth: 2, slug: 'github-activities', text: 'Github Activities' },
]

categoryOrder.forEach((key) => {
  const cat = (categories as any)[key]
  if (cat) {
    headings.push({ depth: 2, slug: key, text: cat.title })
  }
})

headings.push(
  { depth: 2, slug: 'sponsorship', text: 'Sponsorship' }
)

// Group projects by category
const grouped: Record<string, any[]> = {}
for (const [name, proj] of Object.entries(projects) as [string, any][]) {
  const cat = proj.category || 'others'
  if (!grouped[cat]) grouped[cat] = []
  grouped[cat].push({ name, ...proj })
}
---

<PageLayout title='项目' {headings} view>
  <h2 id="github-activities">Github Activities</h2>
  <p>如果我的项目对你有帮助，欢迎赞助支持我的工作。</p>
  <p>
    <img
      src="https://ghchart.rshah.org/659eb9/gitfox-enter"
      alt="GitHub contribution graph"
      width="100%"
      loading="lazy"
      style="width: 100%; border-radius: 0.5rem;"
    />
  </p>

  {categoryOrder.map((catKey: string) => {
    const cat = (categories as any)[catKey] as { title: string; description: string } | undefined
    const items = grouped[catKey] || []
    if (!cat) return null
    return (
      <div>
        <h2 id={catKey}>{cat.title}</h2>
        <div class="grid grid-cols-1 gap-x-4 gap-y-3 sm:grid-cols-2 sm:gap-y-4">
          {items.map((proj: any) => {
            const mainLink = proj.repo
              ? `https://github.com/${proj.repo}`
              : (proj.homepage || '#')
            const homepage = proj.links?.homepage
            const hasGithub = proj.links?.github
            const hasScriptcat = proj.links?.scriptcat
            return (
              <div class="project-card overflow-hidden rounded-xl border">
                <div class="flex flex-col gap-y-1 px-2 py-1.5 sm:px-3 sm:py-2">
                  <a class="project-title line-clamp-1 font-medium no-underline transition-colors" href={mainLink} target="_blank" rel="noopener noreferrer">
                    {proj.title} {proj.label && <span class="project-label">[{proj.label}]</span>}
                  </a>
                  <div class="project-desc line-clamp-2 text-sm leading-snug">
                    {proj.description || ''}
                  </div>
                  <div class="flex items-center gap-x-2 sm:gap-x-3">
                    {hasGithub && proj.repo && (
                      <a href={`https://github.com/${proj.repo}`} class="icon-link" aria-label="github" target="_blank" rel="noopener noreferrer">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"><path fill="currentColor" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49c.5.092.682-.217.682-.482c0-.237-.009-.866-.013-1.7c-2.782.604-3.369-1.34-3.369-1.34c-.454-1.156-1.11-1.463-1.11-1.463c-.908-.62.069-.608.069-.608c1.003.07 1.531 1.03 1.531 1.03c.892 1.529 2.341 1.087 2.91.831c.092-.646.35-1.086.636-1.336c-2.22-.253-4.555-1.11-4.555-4.943c0-1.091.39-1.984 1.029-2.683c-.103-.253-.446-1.27.098-2.647c0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025c.546 1.377.203 2.394.1 2.647c.64.699 1.028 1.592 1.028 2.683c0 3.842-2.339 4.687-4.566 4.935c.359.309.678.919.678 1.852c0 1.336-.012 2.415-.012 2.743c0 .267.18.578.688.48C19.138 20.167 22 16.418 22 12c0-5.523-4.477-10-10-10z"/></svg>
                      </a>
                    )}
                    {homepage && (
                      <a href={homepage} class="icon-link" aria-label="homepage" target="_blank" rel="noopener noreferrer">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"><path fill="currentColor" d="M10 6v2H5v11h11v-5h2v6a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V7a1 1 0 0 1 1-1zm6-2h5v5h-2V6.414l-5.293 5.293l-1.414-1.414L17.586 5H14z"/></svg>
                      </a>
                    )}
                    {hasScriptcat && (
                      <a href={proj.homepage || '#'} class="icon-link" aria-label="scriptcat" target="_blank" rel="noopener noreferrer">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"><path fill="currentColor" d="M3 3h18v18H3zm2 2v14h14V5zm2 2h10v2H7zm0 4h10v2H7zm0 4h7v2H7z"/></svg>
                      </a>
                    )}
                  </div>
                </div>
              </div>
            )
          })}
        </div>
      </div>
    )
  })}

  <h2 id="sponsorship">Sponsorship</h2>
  <p>
    如果我的项目对你有帮助，欢迎赞助支持我的工作 ☕
  </p>
  <Sponsorship
    methods={[
      { name: '微信赞赏', icon: 'wechat-pay', image: wechat }
    ]}
  />
</PageLayout>

<style>
  .project-card {
    position: relative;
  }

  .project-title {
    color: hsl(var(--foreground));
  }

  .project-title:hover {
    color: hsl(var(--primary));
  }

  .project-label {
    font-weight: 400;
    font-size: 0.85em;
    color: hsl(var(--muted-foreground));
  }

  .project-desc {
    color: hsl(var(--muted-foreground));
    min-height: 2.5em;
  }

  .icon-link {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.25rem;
    border-radius: 9999px;
    background: hsl(var(--muted));
    color: hsl(var(--muted-foreground));
    transition: all 0.2s;
  }

  .icon-link:hover {
    color: hsl(var(--foreground));
    background: hsl(var(--accent));
  }

  .icon-link svg {
    width: 18px;
    height: 18px;
  }
</style>
