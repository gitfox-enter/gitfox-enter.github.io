---
import { Button, Timeline } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'
import ToolSection from '@/components/about/ToolSection.astro'

const headings = [
  { depth: 2, slug: 'tools', text: '常用工具' },
  { depth: 2, slug: 'history', text: '博客历程' },
  { depth: 2, slug: 'contact', text: '联系我' }
]
---

<PageLayout title='关于' {headings} comment>
  <p>
    你好，我是 GitFox。
  </p>
  <p>
    一个还在摸索中的初学者。不会的东西比会的多，但保持好奇心，喜欢用代码解决实际问题，能用脚本自动化的事情绝不手动重复。
  </p>
  <p>
    目前在探索 AI 编程，边学边做，边做边学。
  </p>
  <Button title='请我喝杯咖啡 ☕' class='w-fit' href='/projects#sponsorship' variant='ahead' />

  <h2 id='tools'>常用工具</h2>

  <ToolSection
    title='开发工具'
    tools={[
      {
        name: 'VS Code',
        description: '代码编辑器',
        href: 'https://code.visualstudio.com/',
        icon: import('@/assets/tools/vscode.svg?raw')
      },
      {
        name: 'Git',
        description: '版本控制',
        href: 'https://git-scm.com/',
        icon: import('@/assets/tools/git.svg?raw')
      },
      {
        name: 'GitHub',
        description: '开源社区',
        href: 'https://github.com/gitfox-enter',
        icon: import('@/assets/tools/github.svg?raw')
      },
      {
        name: 'Docker',
        description: '容器化部署',
        href: 'https://www.docker.com/',
        icon: import('@/assets/tools/docker.svg?raw')
      }
    ]}
  />

  <ToolSection
    title='运行环境'
    tools={[
      {
        name: 'Node.js',
        description: 'JavaScript 运行时',
        href: 'https://nodejs.org/',
        icon: import('@/assets/tools/node.js.svg?raw')
      },
      {
        name: 'Python',
        description: '脚本开发',
        href: 'https://www.python.org/',
        icon: import('@/assets/tools/python.svg?raw')
      },
      {
        name: 'Bun',
        description: '快速包管理器',
        href: 'https://bun.sh/',
        icon: import('@/assets/tools/bun.svg?raw')
      }
    ]}
  />

  <ToolSection
    title='系统 & 其他'
    tools={[
      {
        name: 'Windows 11',
        description: '主力系统',
        href: 'https://www.microsoft.com/windows',
        icon: import('@/assets/tools/windows11.svg?raw')
      },
      {
        name: 'Chrome',
        description: '浏览器',
        href: 'https://www.google.com/chrome/',
        icon: import('@/assets/tools/chrome.svg?raw')
      }
    ]}
  />

  <h2 id='history'>博客历程</h2>
  <Timeline
    events={[
      {
        date: '2026-06',
        content:
          '迁移至 <a href="https://github.com/cworld1/astro-theme-pure" target="_blank">astro-theme-pure</a> 主题，使用 Bun + GitHub Actions 自动部署'
      },
      {
        date: '2026-05',
        content:
          '基于 Astro 搭建个人博客，部署到 <a href="https://pages.github.com/" target="_blank">GitHub Pages</a>'
      }
    ]}
  />
  <p class='mt-4 text-sm text-muted-foreground'>
    本站基于 <a href='https://astro.build/' target='_blank' class='underline'>Astro</a> +
    <a href='https://github.com/cworld1/astro-theme-pure' target='_blank' class='underline'>Astro Theme Pure</a> 构建，
    托管于 <a href='https://pages.github.com/' target='_blank' class='underline'>GitHub Pages</a>。
  </p>

  <h2 id='contact'>联系我</h2>
  <p>
    目前主要通过 GitHub 交流，欢迎来逛逛：
  </p>
  <Button title='GitHub @gitfox-enter' href='https://github.com/gitfox-enter' target='_blank' variant='ahead' />
</PageLayout>
