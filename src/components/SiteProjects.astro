---
interface SiteItem {
  name: string
  url: string
  repo: string
  description: string
  language: string
  langColor: string
}

const sites: SiteItem[] = [
  {
    name: 'GitFox Blog',
    url: 'https://gitfox-enter.github.io/',
    repo: 'gitfox-enter.github.io',
    description: '个人博客，分享项目展示、技术文章与自动化实践',
    language: 'Astro',
    langColor: '#ff5a03'
  },
  {
    name: 'RSSForge',
    url: 'https://gitfox-enter.github.io/RSSForge/',
    repo: 'RSSForge',
    description: '基于 GitHub Actions 的免费 RSS 订阅源生成器，给任何网站生成 RSS',
    language: 'Python',
    langColor: '#3572A5'
  },
  {
    name: 'Site Backup',
    url: 'https://gitfox-enter.github.io/site-backup/',
    repo: 'site-backup',
    description: '备份互联网上有价值的博客和网站内容，防止原站失效后资源丢失',
    language: 'MDX',
    langColor: '#fcb32c'
  },
  {
    name: 'Learning Notes',
    url: 'https://gitfox-enter.github.io/github-learning-notes/',
    repo: 'github-learning-notes',
    description: '从零开始学习 GitHub 的完整笔记 — Git 基础、前端开发、Python 脚本',
    language: 'Markdown',
    langColor: '#083fa1'
  }
]
---

<site-projects class="site-projects-container">
  <div class="site-projects-grid">
    {sites.map((site) => (
      <div class="site-card">
        <a class="site-link" href={site.url} target="_blank" rel="noopener noreferrer">
          <div class="site-name">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            {site.name}
          </div>
          <div class="site-desc">{site.description}</div>
        </a>
        <div class="site-meta">
          <a class="repo-badge" href={`https://github.com/gitfox-enter/${site.repo}`} target="_blank" rel="noopener noreferrer">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            {site.repo}
          </a>
          <span class="lang-badge">
            <span class="lang-dot" style={`background-color:${site.langColor}`}></span>
            {site.language}
          </span>
        </div>
      </div>
    ))}
  </div>
</site-projects>

<style>
  .site-projects-container { width: 100%; }
  .site-projects-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }
  @media (min-width: 640px) {
    .site-projects-grid { grid-template-columns: repeat(2, 1fr); }
  }
  .site-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    padding: 0.875rem;
    border-radius: 0.75rem;
    border: 1px solid hsl(var(--border));
    transition: background-color 0.2s, border-color 0.2s;
  }
  .site-card:hover {
    background-color: hsl(var(--muted));
    border-color: hsl(var(--border) / 0.8);
  }
  .site-card a.site-link {
    text-decoration: none;
    color: inherit;
  }
  .site-name {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-weight: 500;
    color: hsl(var(--foreground));
    transition: color 0.2s;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
  }
  .site-name svg {
    flex-shrink: 0;
    opacity: 0.6;
  }
  .site-card:hover .site-name {
    color: hsl(var(--primary));
  }
  .site-desc {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-size: 0.875rem;
    line-height: 1.4;
    color: hsl(var(--muted-foreground));
    min-height: 2.45em;
  }
  .site-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0.125rem;
    flex-wrap: wrap;
  }
  .repo-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.8125rem;
    color: hsl(var(--muted-foreground));
    text-decoration: none;
    transition: color 0.2s;
  }
  .repo-badge:hover {
    color: hsl(var(--primary));
  }
  .repo-badge svg {
    flex-shrink: 0;
    width: 14px;
    height: 14px;
  }
  .lang-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.8125rem;
    color: hsl(var(--muted-foreground));
  }
  .lang-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }
</style>
